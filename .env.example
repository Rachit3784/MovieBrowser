# ============================================
# Environment Variables Template
# ============================================
# 
# Copy this file to .env and fill in your actual values
# The .env file is ignored by git and will NOT be committed
# Each developer must create their own .env file
#
# DO NOT commit .env to GitHub with real API keys!
# ============================================

# TMDB (The Movie Database) API Configuration
# Get your free API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# TMDB API Base URL (usually doesn't need to change)
TMDB_BASE_URL=https://api.themoviedb.org/3

# TMDB Image Base URL (usually doesn't need to change)
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
